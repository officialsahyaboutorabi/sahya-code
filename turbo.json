{
  "$schema": "https://v2-8-13.turborepo.dev/schema.json",
  "globalEnv": ["CI", "SAHYACODE_DISABLE_SHARE", "OPENCODE_DISABLE_SHARE"],
  "globalPassThroughEnv": ["CI", "SAHYACODE_DISABLE_SHARE", "OPENCODE_DISABLE_SHARE"],
  "tasks": {
    "typecheck": {},
    "build": {
      "dependsOn": [],
      "outputs": ["dist/**"]
    },
    "sahyacode#test": {
      "dependsOn": ["^build"],
      "outputs": [],
      "passThroughEnv": ["*"]
    },
    "@sahyacode-ai/app#test": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  }
}
